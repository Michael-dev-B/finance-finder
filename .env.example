# Copy to .env (which is gitignored) and fill in real values.

# --- Backend (server/) ---
# Path to the SQLite database file. Created on first run if missing.
DATABASE_PATH=./data/finance-finder.sqlite

# Port the Express API listens on.
PORT=4000

# --- Frontend (client/) ---
# Base URL the frontend uses to reach the API.
# Must match the backend PORT above in local dev.
VITE_API_BASE_URL=http://localhost:4000
